# Copy this file to .env and fill in your values. .env is gitignored.

# ── Email notification (optional) ────────────────────────────────────────────
# 163 SMTP: get authorization code at mail.163.com → Settings → POP3/SMTP
# Gmail:    get app password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_address@163.com
SMTP_PASSWORD=your_authorization_code
MAIL_TO=recipient@example.com

# ── API Keys ──────────────────────────────────────────────────────────────────
# Gemini — required for --chinese output. Get at https://aistudio.google.com
GEMINI_API_KEY=AIza...

# Firecrawl — enables McKinsey scraping and full-text enrichment.
# Free tier: 500 credits/month. Sign up at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# ── Output directories ────────────────────────────────────────────────────────
# Defaults to ~/Documents/ruoyinote if not set.
OBSIDIAN_DIR=~/Documents/ruoyinote

# NotebookLM plain-text output. Leave empty to disable.
NOTEBOOKLM_DIR=
