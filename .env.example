# Copy this file to .env and fill in your values. .env is gitignored.
#
# Defaults shown below are the actual runtime defaults used when a variable is
# absent from .env. You only need to set a variable when you want a non-default value.

# ── Email notification (optional) ────────────────────────────────────────────
# 163 SMTP: get authorization code at mail.163.com → Settings → POP3/SMTP
# Gmail:    get app password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=your_address@163.com
SMTP_PASSWORD=your_authorization_code
MAIL_TO=recipient@example.com

# Split large digests into multiple emails (articles per email).
# Default: 60. Set to 0 to disable splitting.
MAIL_SPLIT_N=60

# ── Run behavior flags ────────────────────────────────────────────────────────
# Set to 1 to enable, 0 to disable. All default to the shown values.

# Write Obsidian markdown note (default: on)
RUN_MD=1

# Write NotebookLM plain-text file in NOTEBOOKLM_DIR (default: off)
RUN_NOTEBOOK=0

# Skip sending email even when SMTP is configured (default: off)
RUN_NO_MAIL=0

# Translate article titles and summaries to Chinese (default: off)
RUN_CHINESE=0

# ── Translation (--chinese / RUN_CHINESE=1) ───────────────────────────────────
# Select backend: gemini (default) | openai | claude
TRANSLATOR=gemini

# Gemini — free tier, 1500 req/day. Get key at https://aistudio.google.com
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# OpenAI / OpenAI-compatible APIs (Groq, Together, Mistral, etc.)
# TRANSLATOR=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=              # set to provider endpoint to use a compatible API

# Anthropic Claude
# TRANSLATOR=claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-20240307

# ── Firecrawl ─────────────────────────────────────────────────────────────────
# Enables full-text enrichment for blog sources.
# Free tier: 500 credits/month. Sign up at https://firecrawl.dev
FIRECRAWL_API_KEY=fc-...

# ── Output directories ────────────────────────────────────────────────────────
# Defaults to ~/Documents/fairing-vault if not set.
OBSIDIAN_DIR=~/Documents/ruoyinote

# NotebookLM plain-text output. Leave empty to disable.
NOTEBOOKLM_DIR=

# ── Data directory (multi-device sync) ───────────────────────────────────────
# All mutable data files (seen_urls.json, scoring_store.jsonl, etc.) are stored
# here. Point to a cloud-synced folder (OneDrive, Dropbox, iCloud) for seamless
# multi-device use. Defaults to the project root when not set.
DATA_DIR=~/OneDrive/fairing

# ── Backup directory ──────────────────────────────────────────────────────────
# Daily snapshots of data files. Defaults to ~/Documents/fairing/data_bak.
BACKUP_DIR=~/Documents/fairing/data_bak
